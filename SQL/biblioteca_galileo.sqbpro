-- Préstamos (algunos devueltos, otros activos)
INSERT INTO prestamos (usuario_id, libro_id, fecha_prestamo, dias_prestamo, devuelto, fecha_devolucion_real) VALUES
    (1, 1, '2024-01-10', 15, 1, '2024-01-22'),
    (2, 3, '2024-01-15', 15, 1, '2024-01-30'),
    (1, 5, '2024-02-01', 21, 1, '2024-02-20'),
    (3, 2, '2024-02-10', 15, 0, NULL),
    (4, 4, '2024-02-15', 15, 0, NULL),
