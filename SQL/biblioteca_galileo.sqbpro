    (5, 6, '2024-02-25', 15, 0, NULL),
    (2, 5, '2024-03-01', 21, 0, NULL);
	
	SELECT 
    l.titulo,
    a.nombre AS autor,
    e.nombre AS editorial,
    l.año_publicacion
FROM libros l
INNER JOIN autores a ON l.autor_id = a.id
LEFT JOIN editoriales e ON l.editorial_id = e.id
ORDER BY l.titulo;

SELECT DISTINCT
    u.nombre,
    u.email,
    u.telefono
FROM usuarios u
INNER JOIN prestamos p ON u.id = p.usuario_id
WHERE p.devuelto = 0;

SELECT l.titulo, a.nombre AS autor
FROM libros l
INNER JOIN autores a ON l.autor_id = a.id
WHERE l.id NOT IN (SELECT libro_id FROM prestamos);

SELECT 
    u.nombre,
    COUNT(p.id) AS total_prestamos,
    SUM(CASE WHEN p.devuelto = 0 THEN 1 ELSE 0 END) AS prestamos_activos
FROM usuarios u
LEFT JOIN prestamos p ON u.id = p.usuario_id
GROUP BY u.id, u.nombre
ORDER BY total_prestamos DESC;

SELECT 
    l.titulo,
    a.nombre AS autor,
    COUNT(p.id) AS veces_prestado
FROM libros l
INNER JOIN autores a ON l.autor_id = a.id
LEFT JOIN prestamos p ON l.id = p.libro_id
GROUP BY l.id, l.titulo, a.nombre
ORDER BY veces_prestado DESC
LIMIT 5;

SELECT 
    l.titulo,
    COUNT(p.id) AS prestamos,
    ROUND(AVG(p.dias_prestamo), 1) AS promedio_dias
FROM libros l
INNER JOIN prestamos p ON l.id = p.libro_id
GROUP BY l.id, l.titulo
HAVING COUNT(p.id) &gt; 0
ORDER BY promedio_dias DESC;

SELECT 
    u.nombre AS usuario,
    l.titulo AS libro,
    p.fecha_prestamo,
    p.fecha_devolucion_prevista,
    p.fecha_devolucion_real,
    JULIANDAY(p.fecha_devolucion_real) - JULIANDAY(p.fecha_devolucion_prevista) AS dias_retraso
FROM prestamos p
INNER JOIN usuarios u ON p.usuario_id = u.id
INNER JOIN libros l ON p.libro_id = l.id
WHERE p.devuelto = 1
  AND p.fecha_devolucion_real &gt; p.fecha_devolucion_prevista;
  
  SELECT 
    a.nombre AS autor,
    COUNT(p.id) AS total_prestamos
FROM autores a
INNER JOIN libros l ON a.id = l.autor_id
INNER JOIN prestamos p ON l.id = p.libro_id
GROUP BY a.id, a.nombre
ORDER BY total_prestamos DESC
LIMIT 3;


SELECT 
    l.titulo AS libro,
    a.nombre AS autor,
    u.nombre AS usuario,
    u.email,
    p.fecha_prestamo,
    DATE(p.fecha_prestamo, '+' || p.dias_prestamo || ' days') AS fecha_devolucion_prevista,
    p.dias_prestamo
FROM prestamos p
INNER JOIN usuarios u ON p.usuario_id = u.id
INNER JOIN libros l ON p.libro_id = l.id
INNER JOIN autores a ON l.autor_id = a.id
WHERE p.devuelto = 0
ORDER BY p.fecha_prestamo;

SELECT 
    (SELECT COUNT(*) FROM libros) AS total_libros,
    (SELECT COUNT(*) FROM usuarios) AS total_usuarios,
    (SELECT COUNT(*) FROM prestamos) AS total_prestamos,
    (SELECT COUNT(*) FROM prestamos WHERE devuelto = 0) AS prestamos_activos,
    (SELECT ROUND(AVG(dias_prestamo), 1) FROM prestamos) AS promedio_dias_prestamo;
	
	SELECT 
    STRFTIME('%Y-%m', fecha_prestamo) AS mes,
    COUNT(*) AS total_prestamos
FROM prestamos
GROUP BY mes
ORDER BY mes DESC;

SELECT 
    COUNT(*) AS total_devueltos,
    SUM(CASE 
        WHEN fecha_devolucion_real &lt;= fecha_devolucion_prevista THEN 1 
        ELSE 0 
    END) AS devueltos_a_tiempo,
    ROUND(
        SUM(CASE 
            WHEN fecha_devolucion_real &lt;= fecha_devolucion_prevista THEN 1 
            ELSE 0 
        END) * 100.0 / COUNT(*), 
        2
    ) AS porcentaje_a_tiempo
FROM prestamos
WHERE devuelto = 1;

UPDATE prestamos
SET 
    devuelto = 1,
    fecha_devolucion_real = CURRENT_DATE
WHERE id = 4;

-- Actualizar disponibilidad del libro
UPDATE libros
SET disponible = 1
WHERE id = (SELECT libro_id FROM prestamos WHERE id = 4);

UPDATE prestamos
SET 
    devuelto = 1,
    fecha_devolucion_real = CURRENT_DATE
WHERE id = 4;

BEGIN TRANSACTION;

-- Insertar préstamo
INSERT INTO prestamos (usuario_id, libro_id, dias_prestamo, fecha_devolucion_prevista)
VALUES (
    2,  -- Usuario Carlos
    1,  -- Libro Cien años de soledad
    15,
    DATE('now', '+15 days')
);

-- Marcar libro como no disponible
UPDATE libros
SET disponible = 0
WHERE id = 1;

COMMIT;

CREATE VIEW prestamos_activos AS
SELECT 
    p.id,
    u.nombre AS usuario,
    u.email,
    l.titulo AS libro,
    a.nombre AS autor,
    p.fecha_prestamo,
    DATE(p.fecha_prestamo, '+' || p.dias_prestamo || ' days') AS fecha_devolucion_prevista,
    JULIANDAY('now') - JULIANDAY(p.fecha_prestamo) AS dias_transcurridos
FROM prestamos p
INNER JOIN usuarios u ON p.usuario_id = u.id
INNER JOIN libros l ON p.libro_id = l.id
INNER JOIN autores a ON l.autor_id = a.id
WHERE p.devuelto = 0;

-- Usar la vista
SELECT * FROM prestamos_activos;

CREATE VIEW estadisticas_usuarios AS
SELECT 
    u.id,
    u.nombre,
    COUNT(p.id) AS total_prestamos,
    SUM(CASE WHEN p.devuelto = 0 THEN 1 ELSE 0 END) AS prestamos_activos,
    AVG(p.dias_prestamo) AS promedio_dias
FROM usuarios u
LEFT JOIN prestamos p ON u.id = p.usuario_id
GROUP BY u.id, u.nombre;

-- Usar la vista
SELECT * FROM estadisticas_usuarios ORDER BY total_prestamos DESC;


--Desafío 1: Sistema de multas
--Añade una tabla de multas para préstamos con retraso:

CREATE TABLE multas (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    prestamo_id INTEGER NOT NULL,
    importe REAL NOT NULL CHECK (importe &gt;= 0),
    pagada BOOLEAN DEFAULT 0,
    FOREIGN KEY (prestamo_id) REFERENCES prestamos(id)
);


--Inserta multas calculando 0.50€ por día de retraso.

INSERT INTO multas (prestamo_id, importe)
SELECT 
    prestamos.id,
    (dias_prestamo - 10) * 0.5
FROM prestamos
WHERE dias_prestamo &gt; 10;

SELECT * FROM multas;

